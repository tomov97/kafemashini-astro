---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PriceDisplay from '../../components/PriceDisplay.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import BrandSidebar from '../../components/BrandSidebar.astro';
import { products, getProductBySlug, getRelatedProducts, getBrandBySlug, site } from '../../utils/products';
import type { Product } from '../../utils/products';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug!)!;
const brand = getBrandBySlug(product.brand);
const related = getRelatedProducts(product, 4);
const mainImage = product.images.find(img => img.isMain) || product.images[0];
const siteUrl = site.url;

const breadcrumbs = [
  { label: 'Начало', href: '/' },
  ...(brand ? [{ label: brand.displayName, href: `/kafe-mashini/${brand.slug}` }] : []),
  { label: product.name },
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "image": mainImage ? `${siteUrl}${mainImage.src}` : undefined,
  "description": product.description || `${product.name} автоматична кафе машина втора употреба от Швейцария`,
  "brand": {
    "@type": "Brand",
    "name": product.brandDisplayName,
  },
  "offers": {
    "@type": "Offer",
    "url": `${siteUrl}/produkt/${product.slug}`,
    "priceCurrency": "BGN",
    "price": product.price || undefined,
    "availability": product.inStock
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
  },
};
---

<BaseLayout
  title={product.metaTitle || `${product.name} – Кафе машина втора употреба | Кафемашини`}
  description={product.metaDescription || `${product.name} автоматична кафе машина от ${product.brandDisplayName}. ${product.price ? `Цена: ${product.price} лв.` : ''} ${site.warranty} гаранция.`}
  ogImage={mainImage?.src}
  ogType="product"
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar -->
      <BrandSidebar currentBrand={product.brand} />

      <!-- Main content -->
      <div class="flex-1">
        <div class="flex flex-col md:flex-row gap-8 mb-8">
          <!-- Image -->
          <div class="md:w-1/2">
            <div class="bg-cream rounded-xl overflow-hidden aspect-square flex items-center justify-center p-6">
              {mainImage ? (
                <img
                  src={mainImage.src}
                  alt={mainImage.alt || `${product.name} кафе машина`}
                  class="max-w-full max-h-full object-contain"
                />
              ) : (
                <div class="text-muted text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="mt-2 text-sm">Няма снимка</p>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="md:w-1/2">
            <h1 class="font-heading text-3xl md:text-4xl font-bold mb-2">{product.name}</h1>
            <p class="text-muted mb-4">{product.brandDisplayName}</p>

            <div class="mb-6">
              <PriceDisplay
                price={product.price}
                priceEur={product.priceEur}
                originalPrice={product.originalPrice}
                size="lg"
              />
            </div>

            <!-- Stock & Warranty -->
            <div class="flex flex-wrap gap-3 mb-6">
              <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium ${
                product.inStock
                  ? 'bg-green-50 text-green-700'
                  : 'bg-red-50 text-red-700'
              }`}>
                <span class={`w-2 h-2 rounded-full ${product.inStock ? 'bg-green-500' : 'bg-red-500'}`}></span>
                {product.inStock ? 'В наличност' : 'Изчерпано'}
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-primary/5 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                {product.warranty} гаранция
              </span>
            </div>

            {product.description && (
              <div class="prose prose-sm max-w-none text-text/80 mb-6">
                <p>{product.description}</p>
              </div>
            )}

            <!-- CTA -->
            <a
              href={`tel:${site.phone}`}
              class="inline-flex items-center gap-2 bg-accent text-white px-8 py-3.5 rounded-full font-medium hover:bg-accent-light transition-colors text-lg"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
              Поръчай: {site.phoneDisplay}
            </a>
          </div>
        </div>

        <!-- Specs -->
        <ProductSpecs specs={product.specs} />

        <!-- Related -->
        <RelatedProducts products={related} />
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
</BaseLayout>
