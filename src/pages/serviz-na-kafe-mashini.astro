---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ViberIcon from '../components/ViberIcon.astro';
import WhatsAppIcon from '../components/WhatsAppIcon.astro';
import { site } from '../utils/products';

const serviceBrands = [
  { name: 'Saeco', slug: 'saeco', desc: 'Ремонт и профилактика на всички автоматични модели Saeco.', accent: '#e63946' },
  { name: 'DeLonghi', slug: 'delonghi', desc: 'Ремонт и профилактика на всички автоматични модели DeLonghi.', accent: '#284d47' },
  { name: 'Jura', slug: 'jura', desc: 'Ремонт и профилактика на всички автоматични модели Jura.', accent: '#1a1a1a' },
  { name: 'Philips', slug: 'philips', desc: 'Ремонт и профилактика на всички автоматични модели Philips.', accent: '#0050a0' },
];

const steps = [
  { num: '1', title: 'Обадете се', desc: 'Свържете се с нас по телефон или Viber. Ще ви дадем първоначална консултация.' },
  { num: '2', title: 'Изпратете или донесете', desc: `Донесете лично на ${site.address.street}, ${site.address.district}, ${site.address.city} или изпратете с куриер.` },
  { num: '3', title: 'Диагностика и ремонт', desc: 'Установяваме проблема, отстраняваме го с нови части и правим пълна профилактика.' },
  { num: '4', title: 'Вземете я обратно', desc: 'Обаждаме ви се, когато машината е готова. Идвате лично или я изпращаме с куриер.' },
];
---

<BaseLayout
  title="Сервиз за кафемашини София — 18+ години опит | Swiss Coffee"
  description="Професионален сервиз за автоматични кафемашини Saeco, DeLonghi, Jura и Philips в София. Ремонт и пълна профилактика само с нови оригинални части. Обадете се: 0894 807 755"
  bodyClass="!bg-cream"
>

  <!-- Section 1: Hero -->
  <section class="bg-primary pt-6 pb-10 sm:pb-14 gsap-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <Breadcrumbs items={[{ label: 'Начало', href: '/' }, { label: 'Сервиз на кафемашини' }]} dark={false} />

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 sm:gap-10 items-center mt-4">
        <!-- Left: headline + subtitle -->
        <div class="lg:col-span-3 lg:pr-8 gsap-fade-up">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4 sm:mb-6 text-white">Сервиз на кафемашини</h1>
          <p class="text-sm sm:text-base lg:text-lg text-white/70 leading-relaxed">
            Над 18 години ремонтираме и обслужваме автоматични кафемашини в София. Само нови оригинални части — без компромиси.
          </p>
        </div>

        <!-- Right: CTA card -->
        <div class="lg:col-span-2 gsap-fade-up" style="--delay: 0.1s">
          <div class="bg-white/10 border border-white/15 rounded-2xl p-5 sm:p-6 text-white backdrop-blur-sm">
            <p class="text-white/60 text-sm font-medium uppercase tracking-wide mb-3">Свържете се с нас</p>
            <a href={`tel:${site.phone}`} class="inline-flex items-center gap-3 bg-btn hover:bg-btn-hover text-white font-bold text-lg sm:text-xl px-4 py-2.5 rounded-xl mb-4 transition-colors w-full justify-center sm:justify-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
              </svg>
              {site.phoneDisplay}
            </a>
            <div class="space-y-2 text-sm text-white/70">
              <div class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{site.hours}</span>
              </div>
              <div class="flex items-start gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-btn mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{site.address.street}, {site.address.detail}, {site.address.district}, {site.address.city}</span>
              </div>
              <div class="flex items-center gap-2.5">
                <ViberIcon class="h-4 w-4 flex-shrink-0 text-btn" />
                <a href={site.viber} class="hover:text-white transition-colors">Пишете ни във Viber</a>
              </div>
              <div class="flex items-center gap-2.5">
                <WhatsAppIcon class="h-4 w-4 flex-shrink-0 text-btn" />
                <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Пишете ни в WhatsApp</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: What We Do -->
  <section class="bg-cream py-10 sm:py-16 gsap-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center mb-3 gsap-fade-up">Какво правим</h2>
      <p class="text-center text-sm sm:text-base text-text/60 mb-8 sm:mb-12 max-w-2xl mx-auto gsap-fade-up" style="--delay: 0.04s">
        Установяваме проблема, отстраняваме го с нови оригинални части и правим пълна профилактика на машината — стандартно, при всеки ремонт.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 max-w-4xl mx-auto">

        <!-- Card 1: Ремонт -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm flex flex-col gsap-fade-up" style="--delay: 0.08s">
          <div class="bg-primary px-5 sm:px-6 py-4 sm:py-5 flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" />
              </svg>
            </div>
            <h3 class="text-base sm:text-lg font-bold text-white">Диагностика и ремонт</h3>
          </div>
          <div class="px-5 sm:px-6 py-4 sm:py-5 flex flex-col flex-1">
            <p class="text-sm sm:text-base text-text/70 leading-relaxed mb-4">
              Установяваме всички дефекти и ги отстраняваме само с нови оригинални части. Пълната профилактика е включена.
            </p>
            <ul class="space-y-2.5 flex-1">
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Само нови оригинални части
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Пълна профилактика — винаги включена
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Готово до 10 работни дни
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Гаранция на извършения ремонт
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Предаване лично или с куриер
              </li>
            </ul>
          </div>
        </div>

        <!-- Card 2: Самостоятелна профилактика -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm flex flex-col gsap-fade-up" style="--delay: 0.14s">
          <div class="bg-btn px-5 sm:px-6 py-4 sm:py-5 flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-base sm:text-lg font-bold text-white">Пълна профилактика</h3>
          </div>
          <div class="px-5 sm:px-6 py-4 sm:py-5 flex flex-col flex-1">
            <p class="text-sm sm:text-base text-text/70 leading-relaxed mb-4">
              Машината ви работи, но иска поддръжка? Поръчайте профилактика самостоятелно.
            </p>
            <ul class="space-y-2.5 flex-1">
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Проверка и настройка на мелачката
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Декалциране и цялостно почистване
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Смяна на уплътнения и износени части
              </li>
              <li class="flex items-center gap-2.5 text-xs sm:text-sm text-text/80">
                <svg class="h-3.5 w-3.5 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Смазване на движещите се части
              </li>
            </ul>
            <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between">
              <div>
                <span class="text-2xl sm:text-3xl font-bold text-primary">40 EUR</span>
                <span class="text-text/50 text-xs ml-1.5">≈ 78 лв.</span>
              </div>
              <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 bg-btn hover:bg-btn-hover text-white font-semibold text-sm px-5 py-2.5 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
                </svg>
                {site.phoneDisplay}
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Section 4: Process Steps -->
  <section class="bg-primary py-10 sm:py-16 gsap-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center mb-8 sm:mb-12 gsap-fade-up text-white">Как протича ремонтът</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-4">
        {steps.map((step, i) => (
          <div class="flex flex-col items-center text-center relative gsap-fade-up" style={`--delay: ${i * 0.08}s`}>
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-6 left-[calc(50%+28px)] right-[calc(-50%+28px)] border-t-2 border-dashed border-white/30"></div>
            )}
            <div class="w-12 h-12 rounded-full bg-cream text-primary flex items-center justify-center font-bold text-lg relative z-10">
              {step.num}
            </div>
            <h3 class="font-bold text-sm sm:text-base mt-3 mb-1.5 text-white">{step.title}</h3>
            <p class="text-xs sm:text-sm text-white/60 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: Brands We Service -->
  <section class="bg-cream py-10 sm:py-16 gsap-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center mb-8 sm:mb-12 gsap-fade-up">Марки, които обслужваме</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        {serviceBrands.map((brand, i) => (
          <a href={`/kafe-mashini/${brand.slug}`} class="bg-white rounded-2xl overflow-hidden shadow-sm text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300 gsap-fade-up" style={`--delay: ${i * 0.06}s`}>
            <div class="h-1" style={`background-color: ${brand.accent}`}></div>
            <div class="p-5 sm:p-6">
              <h3 class="text-lg sm:text-xl font-bold mb-1.5">{brand.name}</h3>
              <p class="text-xs sm:text-sm text-text/60 leading-relaxed mb-2">{brand.desc}</p>
              <span class="text-xs font-semibold text-btn">Вижте модели →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="text-center text-xs sm:text-sm text-text/50 mt-6 sm:mt-8 gsap-fade-up">
        Обслужваме автоматични кафемашини. Не извършваме ремонт на машини с ръкохватка, с изключение на Saeco и DeLonghi.
      </p>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="bg-primary py-8 gsap-section">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 gsap-fade-up">
      <div class="flex flex-col items-center justify-center gap-4">
        <p class="text-white/70 text-sm">Обадете се — ще се погрижим за машината ви.</p>
        <div class="flex flex-col gap-2 w-full max-w-xs">
          <a
            href={`tel:${site.phone}`}
            class="inline-flex items-center justify-center gap-2 font-semibold px-5 py-2.5 rounded-full text-sm bg-white text-primary hover:bg-white/90 transition-colors whitespace-nowrap"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
            </svg>
            {site.phoneDisplay}
          </a>
          <div class="flex gap-2">
            <a
              href={site.viber}
              class="flex-1 inline-flex items-center justify-center gap-2 font-semibold px-5 py-2.5 rounded-full text-sm bg-[#7360F2] text-white hover:bg-[#5a4bc7] transition-colors whitespace-nowrap"
            >
              <ViberIcon class="h-4 w-4" />
              Viber
            </a>
            <a
              href={site.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 inline-flex items-center justify-center gap-2 font-semibold px-5 py-2.5 rounded-full text-sm bg-[#25D366] text-white hover:bg-[#1ebe5d] transition-colors whitespace-nowrap"
            >
              <WhatsAppIcon class="h-4 w-4" />
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Schema: LocalBusiness + Service -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Swiss Coffee — Сервиз за кафемашини",
    "description": "Професионален сервиз за автоматични кафемашини в София. 18+ години опит, само нови оригинални части.",
    "url": "https://kafemashini.ch/serviz-na-kafe-mashini.html",
    "telephone": "+359 894 807 755",
    "email": "office@kafemashini.ch",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ул. Сливен 23, Магазин 3",
      "addressLocality": "София",
      "addressRegion": "ж.к. Банишора",
      "addressCountry": "BG"
    },
    "openingHours": "Mo-Fr 10:00-17:00",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Услуги",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Ремонт на кафемашини",
            "description": "Диагностика и ремонт на автоматични кафемашини с нови оригинални части"
          }
        },
        {
          "@type": "Offer",
          "price": "40",
          "priceCurrency": "EUR",
          "itemOffered": {
            "@type": "Service",
            "name": "Пълна профилактика на кафемашини",
            "description": "Пълна профилактика — уплътнения, смазване, проверка мелачка, декалциране"
          }
        }
      ]
    }
  })} />

  <!-- Scroll animations via IntersectionObserver -->
  <script>
    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          fadeObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -12% 0px' });

    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          sectionObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });

    document.querySelectorAll('.gsap-fade-up').forEach(el => fadeObserver.observe(el));
    document.querySelectorAll('.gsap-section').forEach(el => sectionObserver.observe(el));
  </script>

</BaseLayout>
