---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProductGrid from '../components/ProductGrid.astro';
import BrandSidebar from '../components/BrandSidebar.astro';
import { products } from '../utils/products';
---

<BaseLayout
  title="Продукти – Кафе машини втора употреба | Кафемашини"
  description="Всички кафе машини втора употреба от Швейцария. SAECO, DeLonghi, Gaggia, Siemens и други марки. 6 месеца гаранция."
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumbs items={[{ label: 'Начало', href: '/' }, { label: 'Продукти' }]} />
    <div class="flex flex-col lg:flex-row gap-8">
      <BrandSidebar />
      <div class="flex-1">
        <h1 class="font-heading text-3xl md:text-4xl font-bold mb-6">Всички продукти</h1>
        <p class="text-text/70 mb-8">Разгледайте нашата пълна колекция от {products.length} кафе машини втора употреба от Швейцария.</p>
        <ProductGrid products={products} />
      </div>
    </div>
  </div>
</BaseLayout>
