---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PaginatedProductGrid from '../../components/PaginatedProductGrid.astro';
import BrandNav from '../../components/BrandNav.astro';
import { brands, getProductsByBrand } from '../../utils/products';

export function getStaticPaths() {
  return brands.map(brand => ({
    params: { brand: brand.slug },
  }));
}

const { brand: brandSlug } = Astro.params;
const brand = brands.find(b => b.slug === brandSlug)!;
const brandProducts = getProductsByBrand(brandSlug!);

const breadcrumbs = [
  { label: 'Начало', href: '/' },
  { label: brand.displayName },
];
---

<BaseLayout
  title={brand.metaTitle || `Кафе машини ${brand.displayName} – втора употреба | Кафемашини`}
  description={brand.metaDescription || `Кафе машини ${brand.displayName} втора употреба от Швейцария. ${brandProducts.length} модела на склад. 12 месеца гаранция.`}
  bodyClass="!bg-cream"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-6 pb-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mb-5 mt-2">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text mb-2">
        <span class="block text-xs font-semibold tracking-widest uppercase text-primary/50 mb-2">Кафе машини</span>
        {brand.displayName}
      </h1>
      <p class="text-sm text-muted">{brandProducts.length} продукта</p>
    </div>

    <BrandNav currentBrand={brandSlug} />

    {brandProducts.length > 0 ? (
      <PaginatedProductGrid products={brandProducts} />
    ) : (
      <p class="text-muted text-center py-12">Няма налични продукти от тази марка в момента.</p>
    )}
  </div>
</BaseLayout>
