---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import BrandSidebar from '../../components/BrandSidebar.astro';
import { brands, getProductsByBrand } from '../../utils/products';

export function getStaticPaths() {
  return brands.map(brand => ({
    params: { brand: brand.slug },
  }));
}

const { brand: brandSlug } = Astro.params;
const brand = brands.find(b => b.slug === brandSlug)!;
const brandProducts = getProductsByBrand(brandSlug!);

const breadcrumbs = [
  { label: 'Начало', href: '/' },
  { label: brand.displayName },
];
---

<BaseLayout
  title={brand.metaTitle || `Кафе машини ${brand.displayName} – втора употреба | Кафемашини`}
  description={brand.metaDescription || `Кафе машини ${brand.displayName} втора употреба от Швейцария. ${brandProducts.length} модела на склад. 6 месеца гаранция.`}
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="flex flex-col lg:flex-row gap-8">
      <BrandSidebar currentBrand={brandSlug} />

      <div class="flex-1">
        <h1 class="font-heading text-3xl md:text-4xl font-bold mb-4">
          Кафе машини {brand.displayName}
        </h1>

        {brand.description && (
          <div class="prose prose-sm max-w-none text-text/80 mb-8">
            <p>{brand.description}</p>
          </div>
        )}

        {brandProducts.length > 0 ? (
          <ProductGrid products={brandProducts} />
        ) : (
          <p class="text-muted text-center py-12">Няма налични продукти от тази марка в момента.</p>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
