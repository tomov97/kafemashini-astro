---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { site, brands, products, getProductsByBrand } from '../utils/products';

const featured = products.filter(p => p.inStock && p.price).slice(0, 8);
// build.format:'file' makes Astro.url.pathname return '/index' for the homepage, not '/'.
// Since this file IS the homepage, we hardcode '/' as the current path.
const currentPath = '/';

// Brand tabs for the products section pill bar
const brandTabs = [
  { slug: 'delonghi', label: 'DeLonghi' },
  { slug: 'saeco',    label: 'Saeco'    },
  { slug: 'philips',  label: 'Philips'  },
  { slug: 'jura',     label: 'Jura'     },
];

// Pre-compute top 6 products per brand for client-side switching
const brandProductsMap: Record<string, { slug: string; name: string; brandDisplayName: string; price: number | null; priceEur: number | null; images: { src: string; alt: string; isMain: boolean }[] }[]> = {};
for (const tab of brandTabs) {
  const all = getProductsByBrand(tab.slug).filter(p => p.inStock);
  brandProductsMap[tab.slug] = all.slice(0, 6).map(p => ({
    slug: p.slug,
    name: p.name,
    brandDisplayName: p.brandDisplayName,
    price: p.price,
    priceEur: p.priceEur,
    images: p.images.map(img => ({ src: img.src, alt: img.alt || '', isMain: img.isMain })),
  }));
}
const defaultBrand = 'delonghi';
const defaultProducts = brandProductsMap[defaultBrand] ?? [];
---

<BaseLayout
  title="Кафемашини – втора употреба от Швейцария | Swiss Coffee"
  description="Автоматични кафе машини втора употреба от Швейцария. Марки SAECO, DeLonghi, Jura и Philips. 12 месеца гаранция. Доставка в цялата страна."
  ogType="website"
>
  <!-- Hero — contained card layout -->
  <section class="bg-cream pt-14 sm:pt-8 pb-8 sm:pb-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="hero-card-container">
        <!-- Text side -->
        <div class="hero-text-side gsap-fade-up">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-3 sm:mb-4 leading-tight text-center sm:text-left">
            <span class="text-highlight">Продажба и сервиз на кафе машини</span>
          </h1>
          <p class="text-text/70 text-sm sm:text-base lg:text-lg mb-6 sm:mb-8 leading-relaxed max-w-md text-center sm:text-left mx-auto sm:mx-0">
            Продажба на напълно обслужени кафе машини от Швейцария и професионален ремонт и поддръжка в България.
          </p>
          <div class="flex gap-3 justify-center sm:justify-start">
            <a href="/produkti.html" class="hero-btn hero-btn-primary inline-flex items-center px-6 sm:px-8 py-3 sm:py-3.5 rounded-full font-semibold text-sm sm:text-base whitespace-nowrap text-white">
              Кафе Машини
            </a>
            <a href="/serviz-na-kafe-mashini.html" class="hero-btn hero-btn-secondary inline-flex items-center px-6 sm:px-8 py-3 sm:py-3.5 rounded-full font-semibold text-sm sm:text-base whitespace-nowrap text-white">
              Нашият Сервиз
            </a>
          </div>
        </div>
        <!-- Image side -->
        <div class="hero-image-side gsap-fade-up" style="--delay: 0.15s">
          <img
            src="/images/hero-header-opt.webp"
            alt="Автоматична кафе машина в модерна кухня"
            class="w-full h-full object-cover"
            style="object-position: 40% 70%"
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges + Services — green section below hero -->
  <section class="bg-primary pt-6 pb-10 gsap-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">

        <!-- Trust Badges — compact shield strip -->
        <div class="flex justify-center items-start gap-10 sm:gap-14 md:gap-20 pb-2 gsap-fade-up">

          <!-- Badge 1: Experience -->
          <div class="trust-badge-wrap">
            <svg class="trust-badge-svg" viewBox="0 0 120 140" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <clipPath id="shield1">
                  <path d="M8,0 H112 Q120,0 120,8 V80 Q120,110 60,140 Q0,110 0,80 V8 Q0,0 8,0 Z"/>
                </clipPath>
              </defs>
              <!-- Cream ring -->
              <path d="M8,0 H112 Q120,0 120,8 V80 Q120,110 60,140 Q0,110 0,80 V8 Q0,0 8,0 Z" fill="#fefbf0"/>
              <!-- Green fill (inset 3px) -->
              <path d="M11,3 H109 Q117,3 117,11 V80 Q117,107 60,136 Q3,107 3,80 V11 Q3,3 11,3 Z" fill="url(#grad1)"/>
              <!-- Inner ring line -->
              <path d="M16,8 H104 Q112,8 112,16 V80 Q112,104 60,130 Q8,104 8,80 V16 Q8,8 16,8 Z" fill="none" stroke="rgba(254,251,240,0.2)" stroke-width="1"/>
              <defs>
                <radialGradient id="grad1" cx="50%" cy="25%" r="70%">
                  <stop offset="0%" stop-color="#3d7a70"/>
                  <stop offset="100%" stop-color="#284d47"/>
                </radialGradient>
              </defs>
            </svg>
            <div class="trust-badge-content">
              <span class="trust-badge-stat">над 18</span>
              <span class="trust-badge-label">години опит</span>
              <span class="trust-badge-sub">в България</span>
            </div>
          </div>

          <!-- Badge 2: Clients -->
          <div class="trust-badge-wrap">
            <svg class="trust-badge-svg" viewBox="0 0 120 140" xmlns="http://www.w3.org/2000/svg">
              <path d="M8,0 H112 Q120,0 120,8 V80 Q120,110 60,140 Q0,110 0,80 V8 Q0,0 8,0 Z" fill="#fefbf0"/>
              <path d="M11,3 H109 Q117,3 117,11 V80 Q117,107 60,136 Q3,107 3,80 V11 Q3,3 11,3 Z" fill="url(#grad2)"/>
              <path d="M16,8 H104 Q112,8 112,16 V80 Q112,104 60,130 Q8,104 8,80 V16 Q8,8 16,8 Z" fill="none" stroke="rgba(254,251,240,0.2)" stroke-width="1"/>
              <defs>
                <radialGradient id="grad2" cx="50%" cy="25%" r="70%">
                  <stop offset="0%" stop-color="#3d7a70"/>
                  <stop offset="100%" stop-color="#284d47"/>
                </radialGradient>
              </defs>
            </svg>
            <div class="trust-badge-content">
              <span class="trust-badge-stat">15 000+</span>
              <span class="trust-badge-label">клиенти</span>
              <span class="trust-badge-sub">доволни клиенти</span>
            </div>
          </div>

          <!-- Badge 3: Warranty -->
          <div class="trust-badge-wrap">
            <svg class="trust-badge-svg" viewBox="0 0 120 140" xmlns="http://www.w3.org/2000/svg">
              <path d="M8,0 H112 Q120,0 120,8 V80 Q120,110 60,140 Q0,110 0,80 V8 Q0,0 8,0 Z" fill="#fefbf0"/>
              <path d="M11,3 H109 Q117,3 117,11 V80 Q117,107 60,136 Q3,107 3,80 V11 Q3,3 11,3 Z" fill="url(#grad3)"/>
              <path d="M16,8 H104 Q112,8 112,16 V80 Q112,104 60,130 Q8,104 8,80 V16 Q8,8 16,8 Z" fill="none" stroke="rgba(254,251,240,0.2)" stroke-width="1"/>
              <defs>
                <radialGradient id="grad3" cx="50%" cy="25%" r="70%">
                  <stop offset="0%" stop-color="#3d7a70"/>
                  <stop offset="100%" stop-color="#284d47"/>
                </radialGradient>
              </defs>
            </svg>
            <div class="trust-badge-content">
              <span class="trust-badge-stat">12</span>
              <span class="trust-badge-label">месеца гаранция</span>
              <span class="trust-badge-sub">на всяка машина</span>
            </div>
          </div>

        </div>

        <!-- Our Services -->
        <h2 class="text-lg sm:text-xl font-semibold text-white text-center mt-8 sm:mt-10 mb-4 sm:mb-6 gsap-fade-up">Нашите услуги</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-6">

          <!-- Card: Coffee Machines -->
          <div class="gsap-fade-up h-full">
            <div class="svc-card svc-card-green h-full">
              <div class="svc-content">
                <h3 class="text-sm sm:text-lg font-bold text-text mb-0.5">Кафе машини</h3>
                <p class="text-text/70 text-xs sm:text-sm leading-snug sm:leading-relaxed mb-2 sm:mb-4">Напълно обслужени автоматични кафе машини от Швейцария с гаранция.</p>
                <ul class="space-y-0.5 sm:space-y-1.5">
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">12 месеца гаранция</span>
                  </li>
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">Обслужени преди продажба</span>
                  </li>
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-btn flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">Подбрани модели за дом и офис</span>
                  </li>
                </ul>
              </div>
              <div class="flex flex-col items-center justify-between flex-shrink-0 self-stretch">
                <div class="svc-icon-badge svc-icon-badge-green">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-7 h-7 sm:w-10 sm:h-10" fill="none">
                    <rect x="6" y="10" width="28" height="26" rx="4" fill="#284d47" stroke="white" stroke-width="2"/>
                    <rect x="6" y="10" width="28" height="9" rx="4" fill="#1f3d38" stroke="white" stroke-width="2"/>
                    <rect x="14" y="13" width="12" height="3" rx="1" fill="#589e94"/>
                    <rect x="8" y="14" width="2" height="2" rx="0.5" fill="white" opacity="0.7"/>
                    <rect x="11" y="14" width="2" height="2" rx="0.5" fill="white" opacity="0.7"/>
                    <rect x="28" y="14" width="2" height="2" rx="0.5" fill="white" opacity="0.7"/>
                    <rect x="31" y="14" width="2" height="2" rx="0.5" fill="white" opacity="0.7"/>
                    <rect x="17" y="19" width="6" height="5" rx="1" fill="#589e94" stroke="white" stroke-width="1.5"/>
                    <rect x="19" y="24" width="1.5" height="3" rx="0.5" fill="white"/>
                    <rect x="21.5" y="24" width="1.5" height="3" rx="0.5" fill="white"/>
                    <rect x="8" y="34" width="24" height="3" rx="2" fill="#589e94" stroke="white" stroke-width="1.5"/>
                    <path d="M16 28 Q16 33 20 33 Q24 33 24 28 Z" fill="white" stroke="white" stroke-width="1"/>
                    <path d="M24 29 Q26 29 26 31 Q26 33 24 33" fill="none" stroke="white" stroke-width="1.2"/>
                    <rect x="34" y="16" width="5" height="16" rx="2.5" fill="#284d47" stroke="white" stroke-width="1.5"/>
                  </svg>
                </div>
                <a href="/produkti.html" class="svc-cta-green inline-flex items-center px-5 py-2 sm:px-6 sm:py-2.5 rounded-full font-semibold text-xs sm:text-sm whitespace-nowrap transition-all">
                  Машини
                </a>
              </div>
            </div>
          </div>

          <!-- Card: Service -->
          <div class="gsap-fade-up h-full" style="--delay: 0.1s">
            <div class="svc-card svc-card-warm h-full">
              <div class="svc-content">
                <h3 class="text-sm sm:text-lg font-bold text-text mb-0.5">Сервиз</h3>
                <p class="text-text/70 text-xs sm:text-sm leading-snug sm:leading-relaxed mb-2 sm:mb-4">Професионален ремонт и поддръжка на кафе машини с нови части и доказан опит.</p>
                <ul class="space-y-0.5 sm:space-y-1.5">
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-amber-700 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">Само нови части</span>
                  </li>
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-amber-700 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">Диагностика и ремонт</span>
                  </li>
                  <li class="flex items-center gap-1.5 sm:gap-2">
                    <svg class="h-3 w-3 sm:h-4 sm:w-4 text-amber-700 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-text/80 text-xs sm:text-sm">Сервиз на водещи марки</span>
                  </li>
                </ul>
              </div>
              <div class="flex flex-col items-center justify-between flex-shrink-0 self-stretch">
                <div class="svc-icon-badge svc-icon-badge-warm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 sm:w-10 sm:h-10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" />
                  </svg>
                </div>
                <a href="/serviz-na-kafe-mashini.html" class="svc-cta-green inline-flex items-center px-5 py-2 sm:px-6 sm:py-2.5 rounded-full font-semibold text-xs sm:text-sm whitespace-nowrap transition-all">
                  Сервиз
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section class="bg-cream py-16 gsap-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <!-- Heading -->
      <div class="text-center mb-5 gsap-fade-up">
        <h2 class="text-3xl md:text-4xl font-bold">Нашите Кафе Машини</h2>
      </div>

      <!-- Brand pill bar -->
      <div class="flex justify-center mb-10 gsap-fade-up px-2">
        <div class="nav-pill-container bg-white rounded-full px-1 py-1.5 flex gap-0 sm:px-3 sm:py-2 sm:gap-1">
          {brandTabs.map((tab, i) => (
            <button
              data-brand={tab.slug}
              class={`brand-pill${i === 0 ? ' nav-pill-active' : ' nav-pill-hover'}`}
            >
              {tab.label}
            </button>
          ))}
          <a href="/produkti.html" class="brand-pill nav-pill-hover">Всички</a>
        </div>
      </div>

      <!-- Product grid (SSR default + client-side switching) -->
      <div id="brand-products" class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6 max-w-5xl mx-auto">
        {defaultProducts.map((product, i) => {
          const img = product.images.find(img => img.isMain) || product.images[0];
          return (
            <a
              href={`/produkt/${product.slug}`}
              class="group flex flex-col bg-white rounded-2xl sm:rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-black/5 hover:-translate-y-1 gsap-fade-up"
              style={`--delay: ${i * 0.05}s`}
            >
              <div class="relative aspect-square overflow-hidden rounded-2xl sm:rounded-3xl m-0.5 sm:m-1 bg-gradient-to-br from-[#2a2a2a] to-[#4a5568]">
                {img ? (
                  <img
                    src={img.src}
                    alt={img.alt || `${product.name} кафе машина`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </div>
              <div class="flex flex-col flex-1 px-2 pt-1.5 pb-2 sm:px-4 sm:pt-3 sm:pb-4">
                <h3 class="font-semibold text-xs sm:text-base text-text group-hover:text-primary transition-colors line-clamp-2 leading-tight mb-0 sm:mb-0.5">{product.name.replace(new RegExp('^' + product.brandDisplayName + '\\s*', 'i'), '')}</h3>
                <p class="text-[10px] sm:text-sm text-muted mb-1.5 sm:mb-2">{product.brandDisplayName}</p>
                <div class="mt-auto">
                  {product.price ? (
                    <p class="text-xs sm:text-sm text-text mb-1.5 sm:mb-2">{product.priceEur ? <><span class="font-bold">{product.priceEur.toFixed(0)} €</span> <span class="text-muted font-normal">/ {product.price} лв.</span></> : <span class="font-bold">{product.price} лв.</span>}</p>
                  ) : (
                    <p class="text-[10px] sm:text-sm text-muted italic mb-1.5 sm:mb-2">По запитване</p>
                  )}
                  <span class="block bg-primary text-white text-[10px] sm:text-xs font-semibold px-3 py-1.5 sm:px-4 sm:py-2 rounded-full group-hover:bg-btn transition-colors duration-200 text-center">Разгледай</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- CTA -->
      <div class="text-center mt-6 sm:mt-10 gsap-fade-up">
        <a id="brand-cta" href="/kafe-mashini/delonghi" class="hero-btn hero-btn-primary inline-flex items-center text-white px-5 py-2.5 sm:px-8 sm:py-3.5 rounded-full font-medium text-sm sm:text-base">
          <span id="brand-cta-text">Всички машини DeLonghi</span>
        </a>
      </div>

    </div>
  </section>

  <!-- Google Reviews / Social Proof -->
  <section class="bg-primary py-8 sm:py-12 gsap-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-lg sm:text-xl font-semibold text-white/90 text-center mb-5 sm:mb-8 gsap-fade-up">Отзиви от клиенти</h2>
      <!-- Review cards — translucent on dark -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-2.5 sm:gap-4 gsap-fade-up">
        {[
          { name: 'Мария П.', text: 'Изключително коректно, надеждно и бързо обслужване! Отлична препоръка за професионално мнение и сервиз!', date: 'март 2026' },
          { name: 'Йордан Й.', text: 'Качествени и бързи услуги. Предлага страхотни проверени кафе машини. Горещо препоръчвам сервиза', date: 'февруари 2026' },
          { name: 'Лозан К.', text: 'Най-добрия сервиз на който съм попадал. Силно препоръчвам!', date: 'февруари 2026' },
        ].map(r => (
          <div class="bg-white/12 rounded-xl px-4 py-3 sm:px-5 sm:py-4 border border-white/15 relative flex flex-col">
            <!-- Google icon -->
            <svg class="absolute top-3 right-3 sm:top-4 sm:right-4 w-4 h-4 opacity-60" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
