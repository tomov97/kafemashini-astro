---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { site, brands, products, getProductsByBrand } from '../utils/products';

const featured = products.filter(p => p.inStock && p.price).slice(0, 8);
// build.format:'file' makes Astro.url.pathname return '/index' for the homepage, not '/'.
// Since this file IS the homepage, we hardcode '/' as the current path.
const currentPath = '/';

// Brand tabs for the products section pill bar
const brandTabs = [
  { slug: 'delonghi', label: 'DeLonghi' },
  { slug: 'saeco',    label: 'Saeco'    },
  { slug: 'philips',  label: 'Philips'  },
  { slug: 'jura',     label: 'Jura'     },
];

// Pre-compute top 6 products per brand for client-side switching
const brandProductsMap: Record<string, { slug: string; name: string; brandDisplayName: string; price: number | null; priceEur: number | null; images: { src: string; alt: string; isMain: boolean }[] }[]> = {};
for (const tab of brandTabs) {
  const all = getProductsByBrand(tab.slug).filter(p => p.inStock);
  brandProductsMap[tab.slug] = all.slice(0, 6).map(p => ({
    slug: p.slug,
    name: p.name,
    brandDisplayName: p.brandDisplayName,
    price: p.price,
    priceEur: p.priceEur,
    images: p.images.map(img => ({ src: img.src, alt: img.alt || '', isMain: img.isMain })),
  }));
}
const defaultBrand = 'delonghi';
const defaultProducts = brandProductsMap[defaultBrand] ?? [];
---

<BaseLayout
  title="Кафемашини – втора употреба от Швейцария | Swiss Coffee"
  description="Автоматични кафе машини втора употреба от Швейцария. Марки SAECO, DeLonghi, Jura и Philips. 12 месеца гаранция. Доставка в цялата страна."
  ogType="website"
  hideHeader={true}
>
  <!-- Hero — integrated header + photo card grid -->
  <section class="bg-cream" style="position: relative; overflow: hidden;">
    <!-- Decorative background brush stroke (anchored via grid) -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 sm:px-6 hero-grid">

      <!-- Row 1, Col 1: Logo -->
      <div class="hero-logo">
        <a href="/" class="inline-flex items-center">
          <img src="/images/logo-opt.webp" alt={site.name} class="h-8 md:h-10 w-auto" />
        </a>
      </div>

      <!-- Row 1, Col 2: Nav (floats above card) -->
      <div class="hero-nav">
        <ul class="hidden lg:flex items-center gap-1 bg-white rounded-full px-2 py-1.5 nav-pill-container">
          {site.navigation.map(item => {
            const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class={`nav-pill px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 block ${
                    isActive
                      ? 'nav-pill-active text-white'
                      : 'text-text/70 hover:text-white nav-pill-hover'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text/80 hover:text-text"
          aria-label="Отвори менюто"
          aria-expanded="false"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu (spans full width) -->
      <div id="mobile-menu" class="hidden lg:hidden hero-mobile-menu border-t border-border/30 pt-4 pb-4">
        <ul class="flex flex-col gap-1">
          {site.navigation.map(item => {
            const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class={`block px-4 py-2.5 rounded-lg font-medium transition-all ${
                    isActive
                      ? 'bg-primary text-white'
                      : 'text-text/80 hover:text-white hover:bg-btn'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Row 2, Col 1: Hero text -->
      <div class="hero-text flex flex-col justify-center gsap-fade-up">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight">
          <span class="text-highlight">Продажба и сервиз на кафе машини</span>
        </h1>
        <p class="text-text/70 text-lg mb-2 leading-relaxed max-w-md">
          Продажба на напълно обслужени кафе машини от Швейцария и професионален ремонт и поддръжка в България.
        </p>
        <div class="text-text text-sm mb-8 leading-snug">
          <p>• 12 месеца гаранция</p>
          <p>• 18+ години на пазара</p>
          <p>• 15 000 обслужени клиенти</p>
        </div>
        <div class="flex gap-3">
          <a href="/produkti.html" class="hero-btn hero-btn-inverted inline-flex items-center px-5 sm:px-8 py-3 sm:py-3.5 rounded-full font-semibold text-sm sm:text-base whitespace-nowrap">
            Кафе Машини
          </a>
          <a href="/serviz-na-kafe-mashini.html" class="hero-btn hero-btn-inverted inline-flex items-center px-5 sm:px-8 py-3 sm:py-3.5 rounded-full font-semibold text-sm sm:text-base whitespace-nowrap">
            Нашият Сервиз
          </a>
        </div>
      </div>

      <!-- Row 1+2, Col 2: Photo card (spans both rows) -->
      <div class="hero-card gsap-fade-up" style="--delay: 0.15s">
        <div class="hero-photo-card">
          <img
            src="/images/hero-header-opt.webp"
            alt="Автоматична кафе машина в модерна кухня"
            class="w-full h-full object-cover"
            style="object-position: 40% center"
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- Why Us — green section right below hero -->
  <section class="bg-primary py-16 gsap-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12 gsap-fade-up">Защо клиентите ни се доверяват?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Card 1 -->
          <div class="gsap-fade-up h-full">
            <div class="why-card h-full">
              <div class="why-card-icon">
