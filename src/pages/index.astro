                    <path d="M5 6h10a2 2 0 012 2v8a2 2 0 01-2 2H5a1 1 0 01-1-1V7a1 1 0 011-1z" />
                    <path d="M17 9h1.5a2 2 0 010 4H17" />
                    <path d="M8 6V4.5a1 1 0 011-1h2a1 1 0 011 1V6" />
                    <line x1="4" y1="18" x2="17" y2="18" />
                    <path d="M7 21h6" />
                    <line x1="10" y1="18" x2="10" y2="21" />
