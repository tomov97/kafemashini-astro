  <!-- Brand pill switching -->
  <script define:vars={{ brandProductsMap, brandTabs }}>
    const grid = document.getElementById('brand-products');
    const pills = document.querySelectorAll('.brand-pill[data-brand]');

    function formatPrice(price, priceEur) {
      if (!price) return '<p class="text-[10px] sm:text-sm text-muted italic mb-1.5 sm:mb-2">По запитване</p>';
      if (priceEur) return `<p class="text-xs sm:text-sm text-text mb-1.5 sm:mb-2"><span class="font-bold">${Math.round(priceEur)} €</span> <span class="text-muted font-normal">/ ${price} лв.</span></p>`;
      return `<p class="text-xs sm:text-sm text-text font-bold mb-1.5 sm:mb-2">${price} лв.</p>`;
    }

    function stripBrand(name, brand) {
      return name.replace(new RegExp('^' + brand + '\\s*', 'i'), '');
    }

    function renderProducts(brandSlug) {
      const items = brandProductsMap[brandSlug] ?? [];
      if (!grid) return;
      grid.innerHTML = items.map((p, i) => {
        const img = p.images.find(x => x.isMain) || p.images[0];
        const imgHtml = img
          ? `<img src="${img.src}" alt="${img.alt || p.name + ' кафе машина'}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />`
          : `<div class="w-full h-full flex items-center justify-center" style="color:rgba(255,255,255,0.3)"><svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>`;
        return `<a href="/produkt/${p.slug}" class="group flex flex-col bg-white rounded-2xl sm:rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-black/5 hover:-translate-y-1">
          <div class="relative aspect-square overflow-hidden rounded-2xl sm:rounded-3xl m-0.5 sm:m-1" style="background:linear-gradient(135deg,#2a2a2a,#4a5568)">${imgHtml}</div>
          <div class="flex flex-col flex-1 px-2 pt-1.5 pb-2 sm:px-4 sm:pt-3 sm:pb-4">
            <h3 class="font-semibold text-xs sm:text-base text-text line-clamp-2 leading-tight mb-0 sm:mb-0.5">${stripBrand(p.name, p.brandDisplayName)}</h3>
            <p class="text-[10px] sm:text-sm text-muted mb-1.5 sm:mb-2">${p.brandDisplayName}</p>
            <div style="margin-top:auto">
              ${formatPrice(p.price, p.priceEur)}
              <span class="block bg-primary text-white text-[10px] sm:text-xs font-semibold px-3 py-1.5 sm:px-4 sm:py-2 rounded-full text-center" onmouseover="this.style.background='#589e94'" onmouseout="this.style.background='#284d47'">Разгледай</span>
            </div>
          </div>
        </a>`;
      }).join('');
    }

    const cta = document.getElementById('brand-cta');
    const ctaText = document.getElementById('brand-cta-text');

    function updateCta(brandSlug) {
      const tab = brandTabs.find(t => t.slug === brandSlug);
      if (!cta || !ctaText || !tab) return;
      cta.href = `/kafe-mashini/${brandSlug}`;
      ctaText.textContent = `Всички машини ${tab.label}`;
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const brand = pill.getAttribute('data-brand');
        pills.forEach(p => {
          p.classList.remove('nav-pill-active');
          p.classList.add('nav-pill-hover');
        });
        pill.classList.add('nav-pill-active');
        pill.classList.remove('nav-pill-hover');
        renderProducts(brand);
        updateCta(brand);
      });
    });
  </script>

  <!-- Scroll animations via IntersectionObserver -->
  <script>
    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          fadeObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -12% 0px' });

    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          sectionObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });

    document.querySelectorAll('.gsap-fade-up').forEach(el => fadeObserver.observe(el));
    document.querySelectorAll('.gsap-section').forEach(el => sectionObserver.observe(el));
  </script>

