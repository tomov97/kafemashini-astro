  <style>
    /*
     * Hero CSS Grid:
     *   col 1 (left ~45%): logo (row 1) + text (row 2)
     *   col 2 (right ~55%): card spans BOTH rows, nav floats on top
     *
     * The card starts at the very top of the grid (row 1),
     * the nav sits in the same cell but at higher z-index,
     * giving the "nav floats above the card" effect.
     */

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      padding-top: 16px;
      padding-bottom: 24px;
    }

    /* Desktop: 2-column grid — only at lg+ to avoid squishing on small laptops */
    @media (min-width: 1024px) {
      .hero-grid {
        grid-template-columns: 44% 56%;
        grid-template-rows: auto 1fr;
        gap: 0 40px;
        padding-top: 16px;
        padding-bottom: 10px;
      }
    }

    @media (min-width: 1280px) {
      .hero-grid {
        gap: 0 56px;
        padding-top: 16px;
        padding-bottom: 12px;
      }
    }

    /* Logo: row 1, col 1 — vertically centered with nav */
    .hero-logo {
      grid-row: 1;
      grid-column: 1;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding: 20px 0 10px 0;
    }

    /* Nav: absolutely positioned to match products page header position */
    .hero-nav {
      grid-row: 1;
      grid-column: 1;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0;
      z-index: 5;
    }

    @media (min-width: 1024px) {
      .hero-nav {
        position: absolute;
        top: 20px;
        left: 0;
        right: 0;
        grid-column: 2;
        justify-content: center;
        padding: 0 24px;
      }
    }

    /* Mobile menu: spans full width below row 1 */
    .hero-mobile-menu {
      grid-row: 2;
      grid-column: 1 / -1;
    }

    /* Text: row 2, col 1 */
    .hero-text {
      grid-row: 3;
      grid-column: 1;
      padding: 24px 0;
    }

    @media (min-width: 1024px) {
      .hero-text {
        grid-row: 2;
        grid-column: 1;
        padding: 0;
      }
    }

    /* Card: spans rows 1+2, col 2 on desktop */
    .hero-card {
      grid-row: 4;
      grid-column: 1;
    }

    @media (min-width: 1024px) {
      .hero-card {
        grid-row: 1 / 3;
        grid-column: 2;
        display: flex;
        flex-direction: column;
        padding-top: 0;
      }
    }

    .hero-photo-card {
      border-radius: 24px;
      overflow: hidden;
      height: 360px;
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.15),
        0 8px 24px rgba(0, 0, 0, 0.08);
    }

    @media (min-width: 1024px) {
      .hero-photo-card {
        height: auto;
        aspect-ratio: 3 / 4;
        max-height: calc(100vh - 36px);
      }
    }

    /* Nav pill styles (duplicated from Header for the integrated hero nav) */
    .nav-pill-container {
      box-shadow:
        0 2px 8px rgba(0, 0, 0, 0.08),
        0 1px 2px rgba(0, 0, 0, 0.04),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .nav-pill-active {
      background: linear-gradient(180deg, #356b63 0%, #284d47 60%, #1f3d38 100%);
      box-shadow:
        0 3px 8px rgba(40, 77, 71, 0.45),
