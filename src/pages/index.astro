                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-text mb-5">12 месеца гаранция</h3>
              <p class="text-text/60 text-base leading-relaxed">12 месеца гаранция на напълно обслужени рециклирани кафе машини, внесени от Швейцария.</p>
            </div>
          </div>

        </div>

        <!-- Our Services -->
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mt-16 mb-12 gsap-fade-up">Нашите услуги</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Card: Coffee Machines -->
          <div class="gsap-fade-up h-full">
            <div class="svc-card svc-card-green h-full">
