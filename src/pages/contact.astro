---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../utils/products';

const googleMapsUrl = "https://www.google.com/maps/place/%D0%9F%D1%80%D0%BE%D0%B4%D0%B0%D0%B6%D0%B1%D0%B0+%D0%B8+%D1%81%D0%B5%D1%80%D0%B2%D0%B8%D0%B7+%D0%BD%D0%B0+%D0%BA%D0%B0%D1%84%D0%B5+%D0%BC%D0%B0%D1%88%D0%B8%D0%BD%D0%B8+%D0%B2%D1%82%D0%BE%D1%80%D0%B0+%D1%80%D1%8A%D0%BA%D0%B0/@42.7086601,23.3051406,17z/data=!3m1!4b1!4m6!3m5!1s0x40aa85574b94a6cf:0xdcf9df985d5e88bf!8m2!3d42.7086601!4d23.3077155!16s%2Fg%2F11clgpd823?entry=ttu";

const helpCards = [
  {
    title: 'Търсите кафемашина?',
    desc: 'Разгледайте нашия каталог с автоматични кафемашини втора употреба от Швейцария.',
    href: '/produkti.html',
    cta: 'Към продуктите',
    icon: 'coffee',
  },
  {
    title: 'Нуждаете се от сервиз?',
    desc: 'Ремонт и профилактика на Saeco, DeLonghi, Jura и Philips — само с нови оригинални части.',
    href: '/serviz-na-kafe-mashini.html',
    cta: 'Към сервиза',
    icon: 'wrench',
  },
  {
    title: 'Въпроси за гаранцията?',
    desc: '12 месеца гаранция на всяка кафемашина, закупена от нас. Научете повече.',
    href: '/garantsiya.html',
    cta: 'Условия за гаранция',
    icon: 'shield',
  },
];
---

<BaseLayout
  title="Контакти — Swiss Coffee | Кафемашини София"
  description="Свържете се с Swiss Coffee в София. Телефон: 0894 807 755, имейл: office@kafemashini.ch. Адрес: ж.к. Банишора, ул. Сливен 23. Работно време: Пон–Пет, 10:00–17:00."
  bodyClass="!bg-cream"
>

  <!-- Section 1: Hero -->
  <section class="bg-cream pt-6 pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <Breadcrumbs items={[{ label: 'Начало', href: '/' }, { label: 'Контакти' }]} />

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-center mt-2">
        <!-- Left: headline + intro -->
        <div class="lg:col-span-3 lg:pr-8">
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Контакти</h1>
          <p class="text-lg text-text/70 leading-relaxed mb-4">
            Ще ви помогнем да изберете подходяща кафемашина или да насрочите сервиз. Обадете се, пишете ни по имейл или ни посетете на място в София.
          </p>
          <p class="text-text/60 leading-relaxed">
            Работим с автоматични кафемашини Saeco, DeLonghi, Jura и Philips — продажба на машини втора употреба от Швейцария и професионален сервиз с 18+ години опит.
          </p>
        </div>

        <!-- Right: CTA card -->
        <div class="lg:col-span-2">
          <div class="bg-primary rounded-2xl p-8 text-white">
            <p class="text-white/60 text-sm font-medium uppercase tracking-wide mb-4">Свържете се с нас</p>
            <a href={`tel:${site.phone}`} class="flex items-center gap-3 text-2xl font-bold mb-5 hover:text-btn transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
              </svg>
              {site.phoneDisplay}
            </a>
            <div class="space-y-2 text-sm text-white/70">
              <div class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
              </div>
              <div class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{site.hours}</span>
              </div>
              <div class="flex items-start gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-btn mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{site.address.street}, {site.address.detail}, {site.address.district}, {site.address.city}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Map + Address -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Left: Address details -->
        <div>
          <p class="text-highlight font-medium mb-2 tracking-wide uppercase text-sm">Намерете ни</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Нашият магазин в София</h2>
          <p class="text-text/70 leading-relaxed mb-6">
            Магазинът и сервизът ни се намират в ж.к. Банишора, на ул. Сливен 23, Магазин 3. Можете да ни посетите лично или да изпратите кафемашината с куриер.
          </p>

          <!-- Address details as list -->
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-cream flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold">Адрес</p>
                <p class="text-text/60">{site.address.street}, {site.address.detail}</p>
                <p class="text-text/60">{site.address.district}, {site.address.city}</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-cream flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold">Работно време</p>
                <p class="text-text/60">Понеделник – Петък: 10:00 – 17:00</p>
                <p class="text-text/60">Събота и Неделя: Затворено</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-cream flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold">Телефон</p>
                <a href={`tel:${site.phone}`} class="text-highlight font-medium hover:underline">{site.phoneDisplay}</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-cream flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold">Имейл</p>
                <a href={`mailto:${site.email}`} class="text-highlight font-medium hover:underline">{site.email}</a>
              </div>
            </div>
          </div>

          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-highlight font-semibold hover:underline"
          >
            Отворете в Google Maps
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

        <!-- Right: Google Maps embed -->
        <div>
          <div class="rounded-2xl overflow-hidden border border-border shadow-lg" style="height: 420px;">
            <iframe
              src="https://maps.google.com/maps?q=ул.+Сливен+23,+ж.к.+Банишора,+София,+България&output=embed&hl=bg&z=16"
              width="100%"
              height="100%"
              style="border: 0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Местоположение на Swiss Coffee — ул. Сливен 23, ж.к. Банишора, София"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Section 3: How Can We Help -->
  <section class="bg-cream py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-highlight font-medium mb-2 tracking-wide uppercase text-sm text-center">Полезни страници</p>
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Как можем да помогнем?</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {helpCards.map(card => (
          <a href={card.href} class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col">
            <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center mb-5">
              {card.icon === 'coffee' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7h-1V4a1 1 0 00-1-1H6a1 1 0 00-1 1v3H4a2 2 0 00-2 2v1a4 4 0 004 4h1.535A7.96 7.96 0 0012 16a7.96 7.96 0 004.465-2H18a4 4 0 004-4V9a2 2 0 00-2-2z" />
                </svg>
              )}
              {card.icon === 'wrench' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              )}
              {card.icon === 'shield' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold mb-3">{card.title}</h3>
            <p class="text-text/60 leading-relaxed mb-4 flex-1">{card.desc}</p>
            <span class="inline-flex items-center gap-1 text-highlight font-semibold text-sm">
              {card.cta}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Final CTA -->
  <section class="bg-primary py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Имате въпрос? Обадете ни се.</h2>
      <p class="text-white/70 text-lg mb-8">Ще ви отговорим в рамките на работния ден.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`tel:${site.phone}`}
          class="inline-flex items-center gap-3 bg-white text-primary font-bold px-8 py-4 rounded-full text-lg hover:bg-cream transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
          </svg>
          {site.phoneDisplay}
        </a>
        <span class="text-white/50">или</span>
        <a
          href={`mailto:${site.email}`}
          class="inline-flex items-center gap-2 text-white/80 font-semibold hover:text-white transition-colors underline underline-offset-4"
        >
          {site.email}
        </a>
      </div>
    </div>
  </section>

  <!-- Schema: LocalBusiness + ContactPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Swiss Coffee",
    "description": "Продажба и сервиз на автоматични кафемашини втора употреба от Швейцария в София. 18+ години опит.",
    "url": "https://kafemashini.ch/contact.html",
    "telephone": "+359 894 807 755",
    "email": "office@kafemashini.ch",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ул. Сливен 23, Магазин 3",
      "addressLocality": "София",
      "addressRegion": "ж.к. Банишора",
      "addressCountry": "BG"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "10:00",
      "closes": "17:00"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 42.7086601,
      "longitude": 23.3077155
    },
    "sameAs": [googleMapsUrl]
  })} />

</BaseLayout>
