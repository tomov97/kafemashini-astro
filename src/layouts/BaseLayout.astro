---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import { site } from '../utils/products';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  hideHeader?: boolean;
  bodyClass?: string;
}

const props = Astro.props;
const { hideHeader = false, bodyClass } = props;
---

<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-cyrillic-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  <SEOHead {...props} />

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": site.businessName,
    "url": site.url,
    "telephone": site.phone,
    "email": site.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": `${site.address.street}, ${site.address.detail}`,
      "addressLocality": site.address.city,
      "addressRegion": site.address.district,
      "addressCountry": "BG"
    }
  })} />
</head>
<body class:list={["min-h-screen flex flex-col bg-surface text-text", bodyClass]}>
  {!hideHeader && <Header />}
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
