---
import { site } from '../utils/products';
import { formatEUR } from '../utils/currency';

interface Props {
  priceEur: number | null;
}

const { priceEur } = Astro.props;
---

<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white border-t border-border shadow-[0_-4px_12px_rgba(0,0,0,0.08)] px-4 py-3 translate-y-full transition-transform duration-300">
  <div class="flex items-center justify-between gap-3">
    <div class="min-w-0">
      {priceEur ? (
        <p class="text-lg font-bold text-primary">{formatEUR(priceEur)}</p>
      ) : (
        <p class="text-sm font-medium text-muted">По запитване</p>
      )}
    </div>
    <div class="flex gap-2">
      <a
        href={`tel:${site.phone}`}
        class="inline-flex items-center justify-center w-11 h-11 border border-primary text-primary rounded-full hover:bg-primary hover:text-white transition-colors"
        aria-label="Обадете се"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
      </a>
    </div>
  </div>
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  const productCta = document.getElementById('product-cta');

  if (stickyCta && productCta) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickyCta.classList.add('translate-y-full');
        } else {
          stickyCta.classList.remove('translate-y-full');
        }
      },
      { threshold: 0 }
    );
    observer.observe(productCta);
  }
</script>
