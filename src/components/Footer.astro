---
import { site, brands } from '../utils/products';
---

<footer class="bg-primary text-cream">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Company info -->
      <div>
        <h3 class="font-heading text-xl font-bold text-white mb-4">{site.name}</h3>
        <p class="text-cream/80 mb-4">{site.tagline}</p>
        <div class="space-y-2 text-sm text-cream/80">
          <p>
            <a href={`tel:${site.phone}`} class="hover:text-accent transition-colors">
              {site.phoneDisplay}
            </a>
          </p>
          <p>
            <a href={`mailto:${site.email}`} class="hover:text-accent transition-colors">
              {site.email}
            </a>
          </p>
          <p>{site.address.city}, {site.address.district}</p>
          <p>{site.address.street}, {site.address.detail}</p>
          <p>{site.hours}</p>
        </div>
      </div>

      <!-- Brands -->
      <div>
        <h3 class="font-heading text-xl font-bold text-white mb-4">Марки</h3>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
          {brands.map(brand => (
            <li>
              <a href={`/kafe-mashini/${brand.slug}`} class="text-cream/80 hover:text-accent transition-colors">
                {brand.displayName}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation + Legal -->
      <div>
        <h3 class="font-heading text-xl font-bold text-white mb-4">Навигация</h3>
        <ul class="space-y-1 text-sm mb-6">
          {site.navigation.map(item => (
            <li>
              <a href={item.href} class="text-cream/80 hover:text-accent transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <ul class="space-y-1 text-sm border-t border-primary-light pt-4">
          {site.legalLinks.map(item => (
            <li>
              <a href={item.href} class="text-cream/60 hover:text-accent transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-primary-light text-center text-sm text-cream/50">
      &copy; {site.copyright}–{new Date().getFullYear()} {site.businessName}. Всички права запазени.
    </div>
  </div>
</footer>
