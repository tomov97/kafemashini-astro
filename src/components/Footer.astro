---
import { site, brands } from '../utils/products';
---

<footer class="bg-primary-dark text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-8 sm:pt-10 pb-4 sm:pb-6">

    <!-- Mobile: compact single-column | Desktop: 3-column grid -->
    <div class="hidden md:flex justify-center mb-8">
      <a href="/">
        <img src="/images/logo-opt.webp" alt={site.name} class="h-7 w-auto brightness-0 invert" />
      </a>
    </div>

    <!-- Desktop layout -->
    <div class="hidden md:grid md:grid-cols-3 gap-6 text-sm text-left">
      <!-- Contact -->
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <a href={`tel:${site.phone}`} class="text-white/70 hover:text-white transition-colors">{site.phoneDisplay}</a>
        </div>
        <div class="flex items-start gap-2">
          <svg class="w-4 h-4 text-white/40 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span class="text-white/70">{site.address.street}, {site.address.detail}<br />{site.address.district}, {site.address.city}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-white/60">{site.hours}</span>
        </div>
      </div>

      <!-- Brands -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-wider mb-3">Марки</h3>
        <ul class="flex flex-wrap gap-x-4 gap-y-0">
          {brands.map(brand => (
            <li>
              <a href={`/kafe-mashini/${brand.slug}`} class="py-1.5 inline-block text-white/70 hover:text-white transition-colors">
                {brand.displayName}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Pages -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-wider mb-3">Страници</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-0">
          {site.navigation.map(item => (
            <li>
              <a href={item.href} class="py-1.5 inline-block text-white/70 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Mobile layout: compact -->
    <div class="md:hidden text-xs text-center">
      <!-- Contact row -->
      <div class="flex items-center justify-center gap-4 text-white/60 mb-3">
        <a href={`tel:${site.phone}`} class="hover:text-white transition-colors">{site.phoneDisplay}</a>
      </div>
      <p class="text-white/50 mb-3">{site.address.street}, {site.address.detail}, {site.address.district}, {site.address.city}</p>
      <p class="text-white/40 mb-5">{site.hours}</p>

      <!-- Brands inline -->
      <div class="flex flex-wrap justify-center gap-x-3 gap-y-0 text-white/50 mb-3">
        {brands.map(brand => (
          <a href={`/kafe-mashini/${brand.slug}`} class="py-1 hover:text-white transition-colors">{brand.displayName}</a>
        ))}
      </div>

      <!-- Pages inline -->
      <div class="flex flex-wrap justify-center gap-x-3 gap-y-0 text-white/50">
        {site.navigation.map(item => (
          <a href={item.href} class="py-1 hover:text-white transition-colors">{item.label}</a>
        ))}
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex flex-col md:flex-row items-center justify-between gap-1.5 sm:gap-2 text-[10px] sm:text-xs text-white/35">
      <span>&copy; 2026 Swiss Coffe. Всички права запазени.</span>
      <div class="flex gap-3 sm:gap-4">
        {site.legalLinks.map(item => (
          <a href={item.href} class="hover:text-white/60 transition-colors">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
