---
import PriceDisplay from './PriceDisplay.astro';
import type { Product } from '../utils/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const mainImage = product.images.find(img => img.isMain) || product.images[0];
---

<a
  href={`/produkt/${product.slug}`}
  class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-border/50"
>
  <div class="aspect-square overflow-hidden bg-cream">
    {mainImage ? (
      <img
        src={mainImage.src}
        alt={mainImage.alt || `${product.name} кафе машина`}
        class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-heading font-semibold text-text group-hover:text-primary transition-colors mb-1 line-clamp-2">
      {product.name}
    </h3>
    <p class="text-xs text-muted mb-2">{product.brandDisplayName}</p>
    <PriceDisplay price={product.price} priceEur={product.priceEur} originalPrice={product.originalPrice} size="sm" />
    {!product.inStock && (
      <span class="inline-block mt-2 text-xs bg-muted/10 text-muted px-2 py-0.5 rounded">Изчерпано</span>
    )}
    {product.onSale && product.inStock && (
      <span class="inline-block mt-2 text-xs bg-accent/10 text-accent px-2 py-0.5 rounded font-medium">Намаление</span>
    )}
  </div>
</a>
