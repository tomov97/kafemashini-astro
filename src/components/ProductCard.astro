---
import PriceDisplay from './PriceDisplay.astro';
import type { Product } from '../utils/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const mainImage = product.images.find(img => img.isMain) || product.images[0];
---

<a
  href={`/produkt/${product.slug}`}
  class="group flex flex-col bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-black/5 hover:-translate-y-1"
>
  <div class="relative aspect-square overflow-hidden rounded-3xl m-1 bg-gradient-to-br from-[#2a2a2a] to-[#4a5568]">
    {mainImage ? (
      <img
        src={mainImage.src}
        alt={mainImage.alt || `${product.name} кафе машина`}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center" style="color:rgba(255,255,255,0.3)">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>
  <div class="flex flex-col flex-1 px-3 pt-2 pb-3">
    <h3 class="font-bold text-sm text-text group-hover:text-primary transition-colors line-clamp-2 leading-snug mb-0.5">
      {product.name}
    </h3>
    <p class="text-xs text-muted mb-2">{product.brandDisplayName}</p>
    <div class="flex items-center justify-between mt-auto">
      <PriceDisplay priceEur={product.priceEur} size="sm" />
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${product.inStock ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600'}`}>
        {product.inStock ? 'Налична' : 'Неналична'}
      </span>
    </div>
    <span class="block mt-2 bg-primary text-white text-xs font-semibold px-3 py-1.5 rounded-full group-hover:bg-btn transition-colors duration-200 text-center">Разгледай</span>
  </div>
</a>
