---
import { site } from '../utils/products';
---

<header class="bg-primary text-white">
  <!-- Top bar with phone -->
  <div class="bg-primary-dark py-2">
    <div class="max-w-7xl mx-auto px-4 flex justify-end items-center text-sm">
      <a href={`tel:${site.phone}`} class="flex items-center gap-2 text-cream hover:text-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        {site.phoneDisplay}
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <span class="font-heading text-2xl md:text-3xl font-bold text-cream">{site.name}</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {site.navigation.map(item => (
          <li>
            <a
              href={item.href}
              class="px-4 py-2 rounded-full text-sm font-medium text-cream/90 hover:text-white hover:bg-primary-light transition-all"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-cream hover:text-white"
        aria-label="Отвори менюто"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-primary-light pt-4">
      <ul class="flex flex-col gap-2">
        {site.navigation.map(item => (
          <li>
            <a
              href={item.href}
              class="block px-4 py-2 rounded-lg text-cream/90 hover:text-white hover:bg-primary-light transition-all"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-4 px-4">
        <a
          href={`tel:${site.phone}`}
          class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-medium hover:bg-accent-light transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Обадете се: {site.phoneDisplay}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
