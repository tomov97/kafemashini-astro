---
import ProductCard from './ProductCard.astro';
import type { Product } from '../utils/products';

interface Props {
  products: Product[];
  perPage?: number;
}

const { products, perPage = 9 } = Astro.props;
const totalPages = Math.ceil(products.length / perPage);
const needsPagination = totalPages > 1;
---

<div class="bg-white rounded-3xl shadow-md border border-black/5 p-3 sm:p-5 lg:p-6" id="product-container">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="product-grid">
    {products.map((product, i) => (
      <div class="product-item" data-index={i} style={i >= perPage ? 'display:none' : ''}>
        <ProductCard product={product} />
      </div>
    ))}
  </div>

  {needsPagination && (
    <nav class="flex items-center justify-center gap-3 mt-6 pt-5 border-t border-black/5" id="pagination" aria-label="Пагинация">
      <button id="prev-btn" class="pg-arrow" disabled aria-label="Предишна страница">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="hidden sm:inline">Назад</span>
      </button>
      <div id="page-numbers" class="flex items-center gap-1.5"></div>
      <button id="next-btn" class="pg-arrow" aria-label="Следваща страница">
        <span class="hidden sm:inline">Напред</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </button>
    </nav>
  )}
</div>

<style>
  .pg-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #284d47;
    background: #f3f4f6;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .pg-arrow:hover:not(:disabled) {
    background: #284d47;
    color: white;
  }

  .pg-arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  @media (max-width: 639px) {
    .pg-arrow {
      padding: 0.45rem 0.6rem;
    }
  }

  .pg-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 9999px;
    border: 2px solid #284d47;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    color: #284d47;
    background: transparent;
  }

  .pg-num:hover {
    background: #589e94;
    border-color: #589e94;
    color: white;
  }

  .pg-num-active {
    background: #284d47;
    border-color: #284d47;
    color: white;
  }

  .pg-num-active:hover {
    background: #284d47;
    border-color: #284d47;
    color: white;
  }
</style>

{needsPagination && (
  <script define:vars={{ totalPages, perPage }}>
    let currentPage = 1;

    const items = document.querySelectorAll('.product-item');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageNumbers = document.getElementById('page-numbers');
    const container = document.getElementById('product-container');

    function showPage(page, pushState = true) {
      currentPage = page;
      const start = (page - 1) * perPage;
      const end = start + perPage;

      items.forEach((item, i) => {
        item.style.display = i >= start && i < end ? '' : 'none';
      });

      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === totalPages;

      renderPageNumbers();

      if (pushState) {
        const url = new URL(window.location.href);
        if (page === 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', page);
        }
        history.pushState({ page }, '', url);
        container.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    const isNarrow = window.innerWidth < 640;
    const btnSize = isNarrow ? '1.8rem' : '2.1rem';
    const btnFont = isNarrow ? '0.7rem' : '0.8rem';
    const baseStyle = `display:inline-flex;align-items:center;justify-content:center;width:${btnSize};height:${btnSize};font-size:${btnFont};font-weight:600;border-radius:9999px;border:2px solid #284d47;cursor:pointer;transition:background 0.15s,color 0.15s,border-color 0.15s;`;
    const inactiveStyle = baseStyle + 'color:#284d47;background:transparent;';
    const activeStyle = baseStyle + 'color:white;background:#284d47;border-color:#284d47;';
    const dotsStyle = `display:inline-flex;align-items:center;justify-content:center;width:${btnSize};height:${btnSize};font-size:0.85rem;color:#6b7280;letter-spacing:0.05em;cursor:default;`;

    function getPageRange(current, total) {
      // Always show: first, last, current, current-1, current+1
      // Fill gaps with ellipsis
      const delta = 1;
      const range = new Set([1, total]);
      for (let i = Math.max(2, current - delta); i <= Math.min(total - 1, current + delta); i++) {
        range.add(i);
      }
      const sorted = [...range].sort((a, b) => a - b);

      const result = [];
      let prev = 0;
      for (const page of sorted) {
        if (page - prev > 1) result.push('…');
        result.push(page);
        prev = page;
      }
      return result;
    }

    function makeNumBtn(page) {
      const btn = document.createElement('button');
      btn.textContent = page;
      const isActive = page === currentPage;
      btn.setAttribute('style', isActive ? activeStyle : inactiveStyle);
      btn.addEventListener('mouseenter', () => {
        if (page !== currentPage) btn.setAttribute('style', baseStyle + 'color:white;background:#589e94;border-color:#589e94;');
      });
      btn.addEventListener('mouseleave', () => {
        if (page !== currentPage) btn.setAttribute('style', inactiveStyle);
      });
      btn.addEventListener('click', () => showPage(page));
      return btn;
    }

    function renderPageNumbers() {
      pageNumbers.innerHTML = '';
      for (const item of getPageRange(currentPage, totalPages)) {
        if (item === '…') {
          const dots = document.createElement('span');
          dots.textContent = '…';
          dots.setAttribute('style', dotsStyle);
          pageNumbers.appendChild(dots);
        } else {
          pageNumbers.appendChild(makeNumBtn(item));
        }
      }
    }

    prevBtn.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
    nextBtn.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });

    // Restore page from URL on load
    const urlPage = parseInt(new URL(window.location.href).searchParams.get('page') || '1', 10);
    const initialPage = urlPage >= 1 && urlPage <= totalPages ? urlPage : 1;
    showPage(initialPage, false);

    // Handle browser back/forward
    window.addEventListener('popstate', (e) => {
      const page = e.state?.page || parseInt(new URL(window.location.href).searchParams.get('page') || '1', 10);
      showPage(page, false);
      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
)}
