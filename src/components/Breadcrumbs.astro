---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  dark?: boolean;
}

const { items, dark = true } = Astro.props;
const siteUrl = Astro.site?.href || 'https://kafemashini.ch';

const schemaItems = items.map((item, index) => ({
  "@type": "ListItem",
  "position": index + 1,
  "name": item.label,
  ...(item.href ? { "item": `${siteUrl}${item.href}` } : {})
}));
---

<nav aria-label="Навигация" class={`text-sm mb-6 ${dark ? 'text-muted' : 'text-white/50'}`}>
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class={dark ? 'text-border' : 'text-white/30'}>/</span>}
        {item.href ? (
          <a href={item.href} class={`transition-colors ${dark ? 'hover:text-primary' : 'hover:text-white'}`}>{item.label}</a>
        ) : (
          <span class={dark ? 'text-text' : 'text-white/80'}>{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": schemaItems
})} />
