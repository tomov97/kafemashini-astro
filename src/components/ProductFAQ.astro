---
import { site } from '../utils/products';

const faqs = [
  {
    q: 'В какво състояние са машините?',
    a: 'Машините са втора употреба. По корпуса може да има козметични следи от употреба. Механично всяка машина преминава пълна профилактика при нас — смяна на уплътнения, смазване на механизмите, проверка на мелачката, декалциране и почистване с нови оригинални части.',
  },
  {
    q: 'Каква е гаранцията?',
    a: `Всяка машина идва с 12 месеца гаранция, покриваща механични неизправности при нормална употреба. Повреди вследствие на неправилна употреба не се покриват. Повече информация на страницата <a href="/garantsiya.html" class="text-highlight hover:underline">Гаранция</a>.`,
  },
  {
    q: 'Как да поръчам?',
    a: `Обадете се на <a href="tel:${site.phone}" class="text-highlight hover:underline">${site.phoneDisplay}</a> или ни пишете във <a href="${site.viber}" class="text-[#7360F2] hover:underline font-medium">Viber</a>. Ще ви консултираме, ще уточним детайлите и ще организираме доставката.`,
  },
  {
    q: 'Доставяте ли в цялата страна?',
    a: 'Да, доставяме в цялата страна с куриер. Можете също да вземете машината лично от нашия магазин в София, ж.к. Банишора.',
  },
];
---

<section class="bg-cream py-12 mt-12 -mx-4 sm:-mx-6 px-4 sm:px-6">
  <div class="max-w-3xl mx-auto">
    <p class="text-highlight font-medium mb-2 tracking-wide uppercase text-sm text-center">Въпроси и отговори</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">Често задавани въпроси</h2>
    <div class="space-y-3">
      {faqs.map(faq => (
        <details class="bg-white rounded-2xl px-6 py-5 shadow-sm group">
          <summary class="font-semibold cursor-pointer list-none flex justify-between items-center gap-4">
            {faq.q}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-highlight transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <p class="mt-3 text-text/70 leading-relaxed" set:html={faq.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]*>/g, ''),
    },
  })),
})} />
